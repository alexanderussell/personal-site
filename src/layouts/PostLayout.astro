---
import BaseLayout from './BaseLayout.astro';
import { SubscribeForm } from '../components/SubscribeForm';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: 'log' | 'guide' | 'experiment';
  subtitle?: string;
  number?: string | number;
}

const { title, description, date, type, subtitle, number } = Astro.props;

const backLinks: Record<string, { href: string; label: string }> = {
  log: { href: '/logs', label: 'Logs' },
  guide: { href: '/guides', label: 'Guides' },
  experiment: { href: '/experiments', label: 'Experiments' },
};

const back = backLinks[type];
const formattedDate = date.toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const formattedNumber =
  typeof number === 'number' ? String(number).padStart(2, '0') : number;
---

<BaseLayout title={`${title} — Alex Russell`} description={description}>
  <article class="relative py-16 sm:py-20">
    <header class="mb-12 sm:mb-14">

      <div class={`post-type-badge post-type-badge--${type} font-mono mb-8 flex flex-col items-center gap-2.5 text-center text-xs font-semibold uppercase tracking-[0.2em] sm:flex-row sm:justify-center sm:gap-2`}>
        <span class="flex items-center gap-2">
          <span class="post-type-badge__icon" aria-hidden="true">
            {type === 'log' && (
              <svg viewBox="0 0 24 24" class="size-4" fill="currentColor">
                <path d="M8 2h12v2H8zM6 4h2v16H6zm14 0h2v16h-2zM4 20h16v2H4zm-2-9h2v9H2zm2-2h2v2H4zm6-3h8v2h-8zm0 4h8v2h-8zm0-2h2v2h-2zm6 0h2v2h-2zm-6 5h8v2h-8zm0 3h4v2h-4z"/>
              </svg>
            )}
            {type === 'guide' && (
              <svg viewBox="0 0 24 24" class="size-4" fill="currentColor">
                <path d="M2 3h9v2H2zM0 19h11v2H0zM13 3h9v2h-9zm0 16h11v2H13zM11 5h2v18h-2zM0 5h2v14H0zm22 0h2v14h-2zm-7 2h5v2h-5zm0 4h5v2h-5zm0 4h2v2h-2z"/>
              </svg>
            )}
            {type === 'experiment' && (
              <svg viewBox="0 0 24 24" class="size-4" fill="currentColor">
                <path d="M8 6h8v2H8zm0-4h8v2H8zm0 6h2v2H8zm6 0h2v2h-2zM6 20h12v2H6zm-2-8h2v8H4zm14 0h2v8h-2zM6 10h2v2H6zm10 0h2v2h-2zM6 4h2v2H6zm10 0h2v2h-2z"/>
              </svg>
            )}
          </span>
          <span class="text-text-secondary">{type}{formattedNumber ? ` ${formattedNumber}` : ''}</span>
        </span>
        {subtitle && (
          <span class="flex items-center gap-2">
            <span class="text-text-secondary hidden sm:inline" aria-hidden="true">&middot;</span>
            <span class="text-text-primary">{subtitle}</span>
          </span>
        )}
      </div>

      <h1 class="font-heading relative left-1/2 mb-4 w-[min(62rem,calc(100vw-3rem))] -translate-x-1/2 text-center text-5xl leading-[0.95] tracking-tight sm:text-6xl md:text-7xl">
        {title}
      </h1>

      <time class="text-text-secondary block text-center text-sm" datetime={date.toISOString()}>
        {formattedDate}
      </time>
    </header>

    <div class="mx-auto max-w-2xl">
      <div class="prose dark:prose-invert mx-auto mt-8 px-4 md:mt-12 lg:mt-16 xl:mt-20">
        <slot />
      </div>

      <div class="newsletter-footer">
        <div class="newsletter-footer__divider"></div>
        <p class="newsletter-footer__label">Subscribe to the newsletter</p>
        <p class="newsletter-footer__body">
          Have my next post drop in your inbox.
        </p>
        <SubscribeForm list="newsletter" client:load />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .newsletter-footer {
    margin-top: 4rem;
    padding: 0 1rem;
  }

  .newsletter-footer__divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: 2rem;
  }

  .newsletter-footer__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0 0 0.5rem;
  }

  .newsletter-footer__body {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--color-text-secondary);
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }

  .post-type-badge__icon {
    line-height: 0;
  }

  .post-type-badge--log .post-type-badge__icon {
    color: #60a5fa;
  }

  .post-type-badge--guide .post-type-badge__icon {
    color: #e67e22;
  }

  .post-type-badge--experiment .post-type-badge__icon {
    color: #eab308;
  }
</style>
