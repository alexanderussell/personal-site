---
import BaseLayout from './BaseLayout.astro';
import { SubscribeForm } from '../components/SubscribeForm';
import GrowthStage from '../components/GrowthStage.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import TypeIcon from '../components/TypeIcon.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: 'note' | 'guide' | 'experiment';
  subtitle?: string;
  number?: string | number;
  status?: 'seedling' | 'growing' | 'evergreen';
  via?: string;
  /** Entry id (slug) — combined with `type` to resolve related posts. */
  id?: string;
  tags?: string[];
  related?: string[];
}

const { title, description, date, type, subtitle, number, status, via, id, tags, related } = Astro.props;

const currentRef = id ? `${type}s/${id}` : undefined;

const backLinks: Record<string, { href: string; label: string }> = {
  note: { href: '/notes', label: 'Notes' },
  guide: { href: '/guides', label: 'Guides' },
  experiment: { href: '/experiments', label: 'Experiments' },
};

const back = backLinks[type];
// Frontmatter dates coerce to UTC midnight — format in UTC so the
// rendered date doesn't shift a day on UTC-negative build machines.
const formattedDate = date.toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});

const formattedNumber =
  typeof number === 'number' ? String(number).padStart(2, '0') : number;
---

<BaseLayout title={`${title} — Alex Russell`} description={description}>
  <article class="relative py-16 sm:py-20">
    <header class="mb-12 sm:mb-14">

      <div class={`post-type-badge post-type-badge--${type} font-mono mb-8 flex flex-col items-center gap-2.5 text-center text-xs font-semibold uppercase tracking-[0.2em] sm:flex-row sm:justify-center sm:gap-2`}>
        <span class="flex items-center gap-2">
          <span class="post-type-badge__icon" aria-hidden="true">
            <TypeIcon type={type} class="size-4" />
          </span>
          <span class="text-text-secondary">{type}{formattedNumber ? ` ${formattedNumber}` : ''}</span>
        </span>
        {subtitle && (
          <span class="flex items-center gap-2">
            <span class="text-text-secondary hidden sm:inline" aria-hidden="true">&middot;</span>
            <span class="text-text-primary">{subtitle}</span>
          </span>
        )}
      </div>

      <h1 class="font-heading relative left-1/2 mb-4 w-[min(62rem,calc(100vw-3rem))] -translate-x-1/2 text-center text-5xl leading-[0.95] tracking-tight sm:text-6xl md:text-7xl">
        {title}
      </h1>

      <time class="text-text-secondary block text-center text-sm" datetime={date.toISOString()}>
        {formattedDate}
      </time>

      {(status || via) && (
        <div class="mt-4 flex flex-col items-center gap-2.5">
          {status && <GrowthStage status={status} />}
          {via && (
            <p class="text-text-secondary m-0 max-w-md px-4 text-center font-mono text-xs leading-relaxed">
              via {via}
            </p>
          )}
        </div>
      )}
    </header>

    <div class="mx-auto max-w-2xl">
      <div class="prose dark:prose-invert mx-auto mt-8 px-4 md:mt-12 lg:mt-16 xl:mt-20">
        <slot />
      </div>

      {currentRef && <RelatedPosts currentRef={currentRef} related={related} tags={tags} />}

      <div class="newsletter-footer">
        <div class="newsletter-footer__divider"></div>
        <p class="newsletter-footer__label">Subscribe to the newsletter</p>
        <p class="newsletter-footer__body">
          Have my next post drop in your inbox.
        </p>
        <SubscribeForm list="newsletter" client:visible />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .newsletter-footer {
    margin-top: 4rem;
    padding: 0 1rem;
  }

  .newsletter-footer__divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: 2rem;
  }

  .newsletter-footer__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0 0 0.5rem;
  }

  .newsletter-footer__body {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--color-text-secondary);
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }

  .post-type-badge__icon {
    line-height: 0;
  }

  .post-type-badge--note .post-type-badge__icon {
    color: var(--color-type-note);
  }

  .post-type-badge--guide .post-type-badge__icon {
    color: var(--color-type-guide);
  }

  .post-type-badge--experiment .post-type-badge__icon {
    color: var(--color-type-experiment);
  }
</style>
