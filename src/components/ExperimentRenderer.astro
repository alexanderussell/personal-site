interface Props {
  id: string;
}

const { id } = Astro.props;

const sourceMap: Record<string, string> = {
  bricklayer: bricklayerSource,
  'generative-logo': generativeLogoSource,
  'hold-to-provision': holdToCommitSource,
  vinyl: vinylPreviewSource,
};

const raw = sourceMap[id] ?? '';

