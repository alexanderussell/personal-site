---
// HoldToCommit.astro
// Press-and-hold pill button with inline spinner, checkmark morph,
// spring animation, and confetti burst. Self-contained.
---

<div class="htc-root" data-htc>
  <div class="htc-stage">
    <canvas class="htc-confetti" data-htc-confetti></canvas>
    <button class="htc-btn" data-htc-btn>
      <div class="htc-icon" data-htc-icon>
        <!-- idle: plus inside circle -->
        <svg class="htc-icon-plus" data-htc-plus viewBox="0 0 32 32" fill="none">
          <circle cx="16" cy="16" r="12" stroke="currentColor" stroke-opacity="0.35" stroke-width="2"/>
          <path d="M16 11v10M11 16h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <!-- holding: progress ring -->
        <svg class="htc-icon-ring" data-htc-spinner viewBox="0 0 32 32" fill="none">
          <circle cx="16" cy="16" r="12" stroke="currentColor" stroke-opacity="0.12" stroke-width="3"/>
          <circle class="htc-ring-progress" data-htc-ring cx="16" cy="16" r="12" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
        </svg>
        <!-- complete: checkmark -->
        <svg class="htc-icon-check" data-htc-check viewBox="0 0 32 32" fill="none">
          <path d="M10 16.5l4.5 4.5L22 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="htc-label" data-htc-label>Provision</span>
    </button>
  </div>

  <div class="htc-controls" data-htc-controls>
    <button class="htc-tune-toggle" data-htc-tune>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>
      <span>tune</span>
    </button>
    <div class="htc-sliders" data-htc-sliders>
      <label class="htc-slider-row">
        <span class="htc-slider-name">Hold duration</span>
        <input type="range" min="400" max="4000" value="1400" step="50" data-htc-param="holdDuration" />
        <span class="htc-slider-val" data-htc-val="holdDuration">1400ms</span>
      </label>
      <label class="htc-slider-row">
        <span class="htc-slider-name">Depress scale</span>
        <input type="range" min="0.85" max="0.99" value="0.92" step="0.005" data-htc-param="depressScale" />
        <span class="htc-slider-val" data-htc-val="depressScale">0.92</span>
      </label>
      <label class="htc-slider-row">
        <span class="htc-slider-name">Spring overshoot</span>
        <input type="range" min="1.0" max="1.35" value="1.15" step="0.005" data-htc-param="springOvershoot" />
        <span class="htc-slider-val" data-htc-val="springOvershoot">1.15</span>
      </label>
      <label class="htc-slider-row">
        <span class="htc-slider-name">Spring duration</span>
        <input type="range" min="150" max="1200" value="600" step="25" data-htc-param="springDuration" />
        <span class="htc-slider-val" data-htc-val="springDuration">600ms</span>
      </label>
      <label class="htc-slider-row">
        <span class="htc-slider-name">Bounce decay</span>
        <input type="range" min="2" max="12" value="5" step="0.5" data-htc-param="bounceDecay" />
        <span class="htc-slider-val" data-htc-val="bounceDecay">5</span>
      </label>
      <label class="htc-slider-row">
        <span class="htc-slider-name">Confetti count</span>
        <input type="range" min="0" max="80" value="35" step="1" data-htc-param="confettiCount" />
        <span class="htc-slider-val" data-htc-val="confettiCount">35</span>
      </label>
      <label class="htc-slider-row">
        <span class="htc-slider-name">Confetti spread</span>
        <input type="range" min="40" max="200" value="100" step="5" data-htc-param="confettiSpread" />
        <span class="htc-slider-val" data-htc-val="confettiSpread">100</span>
      </label>
    </div>
  </div>
</div>

<style is:global>
  /* ── Hold-to-Commit — all selectors namespaced .htc-* ── */

  .htc-root {
    /* Light mode: dark button */
    --htc-btn-bg: #282b3a;
    --htc-btn-text: #f0f0f0;
    --htc-btn-shadow-a: rgba(0, 0, 0, 0.2);
    --htc-btn-shadow-b: rgba(0, 0, 0, 0.14);
    --htc-check-color: #5b8af5;
    --htc-mono: var(--font-mono);

    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    padding: 3rem 1rem;
    font-family: var(--htc-mono);
    user-select: none;
    -webkit-user-select: none;
  }

  /* Dark mode: white button */
  .dark .htc-root {
    --htc-btn-bg: #f0f0f2;
    --htc-btn-text: #2a2d3a;
    --htc-btn-shadow-a: rgba(0, 0, 0, 0.25);
    --htc-btn-shadow-b: rgba(0, 0, 0, 0.10);
    --htc-check-color: #5b8af5;
  }

  /* ── Stage ── */

  .htc-stage {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .htc-confetti {
    position: absolute;
    inset: -100px;
    width: calc(100% + 200px);
    height: calc(100% + 200px);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Pill button ── */

  .htc-btn {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.7rem 1.6rem 0.7rem 0.7rem;
    background: var(--htc-btn-bg);
    border: none;
    border-radius: 999px;
    color: var(--htc-btn-text);
    font-family: var(--htc-mono);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: 0.01em;
    cursor: pointer;
    touch-action: none;
    transform: scale(1);
    transition: box-shadow 0.15s ease;
    box-shadow:
      0 2px 8px var(--htc-btn-shadow-a),
      0 6px 24px var(--htc-btn-shadow-b);
    outline: none;
    will-change: transform;
  }

  .htc-btn:hover {
    box-shadow:
      0 3px 12px var(--htc-btn-shadow-a),
      0 8px 32px var(--htc-btn-shadow-b);
  }

  .htc-label {
    pointer-events: none;
    line-height: 1;
  }

  /* ── Icon container ── */

  .htc-icon {
    position: relative;
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    pointer-events: none;
  }

  .htc-icon svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .htc-icon-plus {
    color: var(--htc-btn-text);
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .htc-icon-ring {
    color: var(--htc-btn-text);
    opacity: 0;
    transform: rotate(-90deg);
    transition: opacity 0.2s ease;
  }

  .htc-ring-progress {
    stroke-dasharray: 75.398; /* 2 * PI * 12 */
    stroke-dashoffset: 75.398;
  }

  .htc-icon-check {
    color: var(--htc-check-color);
    opacity: 0;
    transform: scale(0.5);
    transition: opacity 0.25s ease, transform 0.4s cubic-bezier(0.34, 1.8, 0.64, 1);
  }

  /* State classes */

  .htc-btn.is-holding .htc-icon-plus { opacity: 0; }
  .htc-btn.is-holding .htc-icon-ring { opacity: 1; }

  .htc-btn.is-done .htc-icon-plus { opacity: 0; }
  .htc-btn.is-done .htc-icon-ring { opacity: 0; }
  .htc-btn.is-done .htc-icon-check { opacity: 1; transform: scale(1); }

  /* ── Controls ── */

  .htc-controls {
    width: 100%;
    max-width: 380px;
  }

  .htc-tune-toggle {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text-secondary);
    font-family: var(--htc-mono);
    font-size: 11px;
    padding: 0.3rem 0.6rem;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .htc-tune-toggle:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-secondary);
  }

  .htc-tune-toggle.is-active {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .htc-sliders {
    display: none;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 0.75rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-bg-secondary) 40%, transparent);
  }

  .htc-sliders.is-open {
    display: flex;
  }

  .htc-slider-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 11px;
    color: var(--color-text-secondary);
    cursor: default;
  }

  .htc-slider-name {
    flex-shrink: 0;
    width: 110px;
  }

  .htc-slider-row input[type="range"] {
    flex: 1;
    height: 4px;
    appearance: none;
    -webkit-appearance: none;
    background: var(--color-border);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }

  .htc-slider-row input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-text-primary);
    border: 2px solid var(--color-bg-primary);
    cursor: pointer;
  }

  .htc-slider-row input[type="range"]::-moz-range-thumb {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-text-primary);
    border: 2px solid var(--color-bg-primary);
    cursor: pointer;
  }

  .htc-slider-val {
    flex-shrink: 0;
    width: 52px;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
</style>

<script is:inline>
  (() => {
    const RING_CIRCUMFERENCE = 2 * Math.PI * 12; // r=12 in the SVG

    function initHoldToCommit(root) {
      if (root.dataset.htcInit) return;
      root.dataset.htcInit = '1';

      const btn = root.querySelector('[data-htc-btn]');
      const ring = root.querySelector('[data-htc-ring]');
      const confettiCanvas = root.querySelector('[data-htc-confetti]');
      const tuneBtn = root.querySelector('[data-htc-tune]');
      const sliders = root.querySelector('[data-htc-sliders]');

      if (!btn || !ring || !confettiCanvas) return;

      const confettiCtx = confettiCanvas.getContext('2d');

      // ── Params ──
      const params = {
        holdDuration: 1400,
        depressScale: 0.92,
        springOvershoot: 1.15,
        springDuration: 600,
        bounceDecay: 5,
        confettiCount: 35,
        confettiSpread: 100,
      };

      // ── State ──
      let state = 'idle'; // idle | holding | completing | resetting
      let progress = 0;
      let rafId = null;
      let startTime = 0;

      // ── Ring progress ──
      function setRingProgress(p) {
        const offset = RING_CIRCUMFERENCE * (1 - p);
        ring.style.strokeDashoffset = offset;
      }

      // ── Button scale via direct transform ──
      function setBtnScale(s) {
        btn.style.transform = `scale(${s})`;
      }

      // ── Damped spring animation ──
      // Uses decaying sinusoidal oscillation for a real bouncy feel
      function springTo(from, to, overshoot, duration, decay, onUpdate, onDone) {
        const start = performance.now();
        const amplitude = overshoot - 1; // e.g. 0.15 for 1.15
        const frequency = Math.PI * 2.5; // ~2.5 full oscillations

        function tick(now) {
          let t = Math.min(1, (now - start) / duration);
          // Base progress: fast ease-out
          const base = 1 - Math.pow(1 - t, 3);
          // Decaying bounce
          const bounce = amplitude * Math.sin(t * frequency) * Math.exp(-t * decay);
          const val = from + (to - from) * base + (to - from) * bounce;
          onUpdate(val);
          if (t < 1) {
            requestAnimationFrame(tick);
          } else {
            onUpdate(to);
            if (onDone) onDone();
          }
        }
        requestAnimationFrame(tick);
      }

      // ── Confetti ──
      let confettiParticles = [];
      let confettiRafId = null;

      function resizeConfetti() {
        const rect = confettiCanvas.getBoundingClientRect();
        const dpr = window.devicePixelRatio || 1;
        confettiCanvas.width = rect.width * dpr;
        confettiCanvas.height = rect.height * dpr;
        confettiCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function fireConfetti() {
        resizeConfetti();
        const rect = confettiCanvas.getBoundingClientRect();
        const cx = rect.width / (window.devicePixelRatio || 1) / 2;
        const cy = rect.height / (window.devicePixelRatio || 1) / 2;
        const colors = ['#5b8af5', '#f5a623', '#e74c8b', '#4cd964', '#a78bfa', '#f97316'];

        confettiParticles = [];
        for (let i = 0; i < params.confettiCount; i++) {
          const angle = Math.random() * Math.PI * 2;
          const speed = params.confettiSpread * 0.5 + Math.random() * params.confettiSpread * 0.8;
          confettiParticles.push({
            x: cx,
            y: cy,
            vx: Math.cos(angle) * speed * (0.6 + Math.random() * 0.4),
            vy: Math.sin(angle) * speed * (0.6 + Math.random() * 0.4) - params.confettiSpread * 0.35,
            size: 3 + Math.random() * 5,
            color: colors[Math.floor(Math.random() * colors.length)],
            rotation: Math.random() * Math.PI * 2,
            rotSpeed: (Math.random() - 0.5) * 0.3,
            life: 1,
            decay: 0.012 + Math.random() * 0.01,
            shape: Math.random() > 0.5 ? 'rect' : 'circle',
          });
        }

        if (confettiRafId) cancelAnimationFrame(confettiRafId);
        let lastTime = performance.now();
        animateConfetti(lastTime);
      }

      function animateConfetti(now) {
        const dpr = window.devicePixelRatio || 1;
        const w = confettiCanvas.width / dpr;
        const h = confettiCanvas.height / dpr;
        confettiCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
        confettiCtx.clearRect(0, 0, w, h);

        let alive = false;
        for (const p of confettiParticles) {
          if (p.life <= 0) continue;
          alive = true;
          p.x += p.vx * 0.016;
          p.y += p.vy * 0.016;
          p.vy += 200 * 0.016; // gravity
          p.vx *= 0.99;
          p.rotation += p.rotSpeed;
          p.life -= p.decay;

          confettiCtx.save();
          confettiCtx.translate(p.x, p.y);
          confettiCtx.rotate(p.rotation);
          confettiCtx.globalAlpha = Math.max(0, p.life);
          confettiCtx.fillStyle = p.color;
          if (p.shape === 'rect') {
            confettiCtx.fillRect(-p.size / 2, -p.size * 0.4, p.size, p.size * 0.8);
          } else {
            confettiCtx.beginPath();
            confettiCtx.arc(0, 0, p.size / 2, 0, Math.PI * 2);
            confettiCtx.fill();
          }
          confettiCtx.restore();
        }

        if (alive) {
          confettiRafId = requestAnimationFrame(animateConfetti);
        } else {
          confettiCtx.clearRect(0, 0, w, h);
        }
      }

      // ── Hold loop ──
      function holdLoop(now) {
        if (state !== 'holding') return;
        const elapsed = now - startTime;
        progress = Math.min(1, elapsed / params.holdDuration);
        setRingProgress(progress);

        if (progress >= 1) {
          complete();
          return;
        }
        rafId = requestAnimationFrame(holdLoop);
      }

      function startHold() {
        if (state !== 'idle') return;
        state = 'holding';
        progress = 0;
        startTime = performance.now();
        btn.classList.add('is-holding');
        btn.classList.remove('is-done');
        setRingProgress(0);

        // Bouncy depress
        springTo(1, params.depressScale, 1 + (1 - params.depressScale) * 0.3, 300, 4, setBtnScale);

        rafId = requestAnimationFrame(holdLoop);
      }

      function cancelHold() {
        if (state !== 'holding') return;
        state = 'resetting';
        if (rafId) cancelAnimationFrame(rafId);
        btn.classList.remove('is-holding');

        // Animate ring back
        const fromP = progress;
        const resetStart = performance.now();
        function resetRing(now) {
          const t = Math.min(1, (now - resetStart) / 200);
          setRingProgress(fromP * (1 - t * t));
          if (t < 1) requestAnimationFrame(resetRing);
          else {
            setRingProgress(0);
            state = 'idle';
          }
        }
        requestAnimationFrame(resetRing);

        // Springy bounce back to 1
        springTo(params.depressScale, 1, 1.06, 350, params.bounceDecay, setBtnScale);
      }

      function complete() {
        state = 'completing';
        if (rafId) cancelAnimationFrame(rafId);

        setRingProgress(1);
        btn.classList.remove('is-holding');
        btn.classList.add('is-done');

        // Big bouncy spring back with overshoot
        springTo(
          params.depressScale, 1,
          params.springOvershoot,
          params.springDuration,
          params.bounceDecay,
          setBtnScale,
          () => {
            fireConfetti();
          }
        );

        // Reset after a pause
        setTimeout(() => {
          btn.classList.remove('is-done');
          setRingProgress(0);
          setBtnScale(1);
          state = 'idle';
        }, params.springDuration + 1800);
      }

      // ── Pointer events ──
      btn.addEventListener('pointerdown', (e) => {
        if (e.button !== 0) return;
        btn.setPointerCapture(e.pointerId);
        startHold();
      });

      btn.addEventListener('pointerup', () => cancelHold());
      btn.addEventListener('pointercancel', () => cancelHold());
      btn.addEventListener('contextmenu', (e) => e.preventDefault());

      // ── Tune controls ──
      if (tuneBtn && sliders) {
        tuneBtn.addEventListener('click', () => {
          const open = sliders.classList.toggle('is-open');
          tuneBtn.classList.toggle('is-active', open);
        });

        sliders.querySelectorAll('input[type="range"]').forEach((input) => {
          const param = input.dataset.htcParam;
          const valSpan = root.querySelector(`[data-htc-val="${param}"]`);

          input.addEventListener('input', () => {
            const v = parseFloat(input.value);
            params[param] = v;

            const formats = {
              holdDuration: v => v + 'ms',
              depressScale: v => v.toFixed(2),
              springOvershoot: v => v.toFixed(2),
              springDuration: v => v + 'ms',
              bounceDecay: v => v.toFixed(1),
              confettiCount: v => String(Math.round(v)),
              confettiSpread: v => String(Math.round(v)),
            };
            if (valSpan && formats[param]) valSpan.textContent = formats[param](v);
          });
        });
      }

      // Init
      setRingProgress(0);
    }

    function initAll() {
      document.querySelectorAll('[data-htc]').forEach((el) => {
        if (el instanceof HTMLElement) initHoldToCommit(el);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAll, { once: true });
    } else {
      initAll();
    }
  })();
</script>
