---
import ExperimentRenderer from './ExperimentRenderer.astro';

interface Props {
  href: string;
  type: 'log' | 'guide' | 'experiment';
  title?: string;
  description?: string;
  date: Date;
  isLast?: boolean;
  showTypeLabel?: boolean;
  experimentId?: string;
}

const {
  href,
  type,
  title,
  description,
  date,
  isLast = false,
  showTypeLabel = true,
  experimentId,
} = Astro.props;
---

{
  type === 'experiment' && experimentId ? (
    <article class={`timeline-item timeline-item--${type} group grid grid-cols-1 sm:grid-cols-[2rem_1fr] gap-x-4 gap-y-0`}>
      <div class="timeline-rail hidden sm:block">
        <span class="timeline-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" class="size-5" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Bubbles -->
            <rect x="9" y="0" width="1" height="1" fill="currentColor" />
            <rect x="5" y="2" width="2" height="2" fill="currentColor" />
            <rect x="13" y="1" width="2" height="2" fill="currentColor" />
            <!-- Rim -->
            <rect x="2" y="5" width="16" height="1" fill="currentColor" />
            <!-- Body -->
            <rect x="3" y="6" width="14" height="1" fill="currentColor" />
            <rect x="2" y="7" width="16" height="1" fill="currentColor" />
            <rect x="1" y="8" width="18" height="1" fill="currentColor" />
            <rect x="0" y="9" width="20" height="3" fill="currentColor" />
            <!-- Legs + body -->
            <rect x="0" y="12" width="2" height="4" fill="currentColor" />
            <rect x="3" y="12" width="17" height="3" fill="currentColor" />
            <rect x="2" y="15" width="18" height="1" fill="currentColor" />
            <rect x="1" y="16" width="3" height="1" fill="currentColor" />
            <rect x="5" y="16" width="14" height="1" fill="currentColor" />
            <rect x="1" y="17" width="18" height="1" fill="currentColor" />
            <rect x="2" y="18" width="16" height="1" fill="currentColor" />
            <rect x="3" y="19" width="14" height="1" fill="currentColor" />
          </svg>
        </span>
        {!isLast && <span class="timeline-line" aria-hidden="true"></span>}
      </div>

      <div class="timeline-content">
        <a href={href} class="timeline-heading-link flex items-baseline gap-3 mb-2">
          <!-- Mobile: icon inline with type + date -->
          <div class="flex items-center gap-2 sm:hidden">
            <span class="timeline-icon-inline text-text-secondary" aria-hidden="true">
              <svg viewBox="0 0 20 20" class="size-4" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="9" y="0" width="1" height="1" fill="currentColor" />
                <rect x="5" y="2" width="2" height="2" fill="currentColor" />
                <rect x="13" y="1" width="2" height="2" fill="currentColor" />
                <rect x="2" y="5" width="16" height="1" fill="currentColor" />
                <rect x="3" y="6" width="14" height="1" fill="currentColor" />
                <rect x="2" y="7" width="16" height="1" fill="currentColor" />
                <rect x="1" y="8" width="18" height="1" fill="currentColor" />
                <rect x="0" y="9" width="20" height="3" fill="currentColor" />
                <rect x="0" y="12" width="2" height="4" fill="currentColor" />
                <rect x="3" y="12" width="17" height="3" fill="currentColor" />
                <rect x="2" y="15" width="18" height="1" fill="currentColor" />
                <rect x="1" y="16" width="3" height="1" fill="currentColor" />
                <rect x="5" y="16" width="14" height="1" fill="currentColor" />
                <rect x="1" y="17" width="18" height="1" fill="currentColor" />
                <rect x="2" y="18" width="16" height="1" fill="currentColor" />
                <rect x="3" y="19" width="14" height="1" fill="currentColor" />
              </svg>
            </span>
            {showTypeLabel && (
              <span class="text-text-secondary font-mono text-[11px] font-semibold uppercase tracking-[0.08em]">
                {type}
              </span>
            )}
            <time class="text-text-secondary font-mono text-[13px]" datetime={date.toISOString()}>
              {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
          </div>
          <!-- Desktop: type + date (icon is in the rail) -->
          <div class="hidden sm:flex items-baseline gap-3">
            {showTypeLabel && (
              <span class="text-text-secondary font-mono text-[11px] font-semibold uppercase tracking-[0.08em]">
                {type}
              </span>
            )}
            <time class="text-text-secondary font-mono text-[13px]" datetime={date.toISOString()}>
              {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
          </div>
        </a>

        <!-- Desktop: experiment + maximize icon side by side -->
        <div class="flex items-start gap-3">
          <div class="experiment-container w-full sm:w-fit sm:max-w-xl" data-experiment-home data-experiment-href={href}>
            <ExperimentRenderer id={experimentId} />
          </div>
          <!-- TODO: Re-enable maximize button
          <button
            type="button"
            class="experiment-maximize hidden sm:block shrink-0 mt-1"
            aria-label="Open experiment in lightbox"
            data-experiment-maximize
          >
            <svg viewBox="0 0 16 16" class="size-4" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="0" y="0" width="6" height="2" fill="currentColor" />
              <rect x="0" y="2" width="2" height="4" fill="currentColor" />
              <rect x="10" y="0" width="6" height="2" fill="currentColor" />
              <rect x="14" y="2" width="2" height="4" fill="currentColor" />
              <rect x="0" y="10" width="2" height="4" fill="currentColor" />
              <rect x="0" y="14" width="6" height="2" fill="currentColor" />
              <rect x="14" y="10" width="2" height="4" fill="currentColor" />
              <rect x="10" y="14" width="6" height="2" fill="currentColor" />
            </svg>
          </button>
          -->
        </div>
      </div>
    </article>
  ) : (
    <a href={href} class={`timeline-item timeline-item--${type} group grid grid-cols-1 sm:grid-cols-[2rem_1fr] gap-x-4 gap-y-0`}>
      <div class="timeline-rail hidden sm:block">
        <span class="timeline-icon" aria-hidden="true">
          {type === 'log' && (
            <svg viewBox="0 0 20 20" class="size-5" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Top edge + dog-ear -->
              <rect x="4" y="1" width="10" height="1" fill="currentColor" />
              <rect x="3" y="2" width="2" height="1" fill="currentColor" />
              <rect x="13" y="2" width="2" height="1" fill="currentColor" />
              <rect x="3" y="3" width="1" height="1" fill="currentColor" />
              <rect x="14" y="3" width="2" height="1" fill="currentColor" />
              <rect x="3" y="4" width="1" height="1" fill="currentColor" />
              <rect x="15" y="4" width="2" height="1" fill="currentColor" />
              <!-- Left/right edges -->
              <rect x="3" y="5" width="1" height="12" fill="currentColor" />
              <rect x="16" y="5" width="1" height="12" fill="currentColor" />
              <!-- Text lines -->
              <rect x="5" y="4" width="4" height="1" fill="currentColor" />
              <rect x="10" y="4" width="1" height="1" fill="currentColor" />
              <rect x="5" y="6" width="7" height="1" fill="currentColor" />
              <rect x="5" y="8" width="6" height="1" fill="currentColor" />
              <rect x="12" y="8" width="3" height="1" fill="currentColor" />
              <rect x="5" y="10" width="3" height="1" fill="currentColor" />
              <rect x="9" y="10" width="6" height="1" fill="currentColor" />
              <rect x="5" y="12" width="9" height="1" fill="currentColor" />
              <rect x="5" y="14" width="6" height="1" fill="currentColor" />
              <rect x="12" y="14" width="3" height="1" fill="currentColor" />
              <!-- Bottom -->
              <rect x="3" y="17" width="14" height="1" fill="currentColor" />
              <rect x="4" y="18" width="12" height="1" fill="currentColor" />
            </svg>
          )}
          {type === 'guide' && (
            <svg viewBox="0 0 20 20" class="size-5" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Top bar -->
              <rect x="5" y="0" width="13" height="1" fill="currentColor" />
              <rect x="4" y="1" width="1" height="1" fill="currentColor" />
              <rect x="18" y="1" width="1" height="1" fill="currentColor" />
              <!-- Curl -->
              <rect x="16" y="2" width="1" height="1" fill="currentColor" />
              <rect x="18" y="2" width="1" height="1" fill="currentColor" />
              <rect x="16" y="3" width="3" height="1" fill="currentColor" />
              <rect x="16" y="4" width="2" height="1" fill="currentColor" />
              <!-- Left edge -->
              <rect x="3" y="2" width="1" height="14" fill="currentColor" />
              <!-- Right edge -->
              <rect x="16" y="5" width="1" height="12" fill="currentColor" />
              <!-- Text lines -->
              <rect x="6" y="4" width="9" height="1" fill="currentColor" />
              <rect x="5" y="6" width="6" height="1" fill="currentColor" />
              <rect x="12" y="6" width="3" height="1" fill="currentColor" />
              <rect x="5" y="8" width="8" height="1" fill="currentColor" />
              <rect x="5" y="10" width="4" height="1" fill="currentColor" />
              <rect x="5" y="12" width="7" height="1" fill="currentColor" />
              <!-- Bottom roll -->
              <rect x="2" y="16" width="13" height="1" fill="currentColor" />
              <rect x="1" y="17" width="1" height="1" fill="currentColor" />
              <rect x="13" y="17" width="1" height="1" fill="currentColor" />
              <rect x="1" y="18" width="1" height="1" fill="currentColor" />
              <rect x="14" y="18" width="2" height="1" fill="currentColor" />
              <rect x="2" y="19" width="14" height="1" fill="currentColor" />
            </svg>
          )}
          {type === 'experiment' && (
            <svg viewBox="0 0 20 20" class="size-5" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Bubbles -->
              <rect x="9" y="0" width="1" height="1" fill="currentColor" />
              <rect x="5" y="2" width="2" height="2" fill="currentColor" />
              <rect x="13" y="1" width="2" height="2" fill="currentColor" />
              <!-- Rim -->
              <rect x="2" y="5" width="16" height="1" fill="currentColor" />
              <!-- Body -->
              <rect x="3" y="6" width="14" height="1" fill="currentColor" />
              <rect x="2" y="7" width="16" height="1" fill="currentColor" />
              <rect x="1" y="8" width="18" height="1" fill="currentColor" />
              <rect x="0" y="9" width="20" height="3" fill="currentColor" />
              <!-- Legs + body -->
              <rect x="0" y="12" width="2" height="4" fill="currentColor" />
              <rect x="3" y="12" width="17" height="3" fill="currentColor" />
              <rect x="2" y="15" width="18" height="1" fill="currentColor" />
              <rect x="1" y="16" width="3" height="1" fill="currentColor" />
              <rect x="5" y="16" width="14" height="1" fill="currentColor" />
              <rect x="1" y="17" width="18" height="1" fill="currentColor" />
              <rect x="2" y="18" width="16" height="1" fill="currentColor" />
              <rect x="3" y="19" width="14" height="1" fill="currentColor" />
            </svg>
          )}
        </span>
        {!isLast && <span class="timeline-line" aria-hidden="true"></span>}
      </div>

      <div class="timeline-content">
        <!-- Mobile: icon + type inline, stacked above title -->
        <div class="flex items-center gap-2 sm:hidden">
          <span class="timeline-icon-inline text-text-secondary" aria-hidden="true">
            {type === 'log' && (
              <svg viewBox="0 0 20 20" class="size-4" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="1" width="10" height="1" fill="currentColor" />
                <rect x="3" y="2" width="2" height="1" fill="currentColor" />
                <rect x="13" y="2" width="2" height="1" fill="currentColor" />
                <rect x="3" y="3" width="1" height="1" fill="currentColor" />
                <rect x="14" y="3" width="2" height="1" fill="currentColor" />
                <rect x="3" y="4" width="1" height="1" fill="currentColor" />
                <rect x="15" y="4" width="2" height="1" fill="currentColor" />
                <rect x="3" y="5" width="1" height="12" fill="currentColor" />
                <rect x="16" y="5" width="1" height="12" fill="currentColor" />
                <rect x="5" y="4" width="4" height="1" fill="currentColor" />
                <rect x="10" y="4" width="1" height="1" fill="currentColor" />
                <rect x="5" y="6" width="7" height="1" fill="currentColor" />
                <rect x="5" y="8" width="6" height="1" fill="currentColor" />
                <rect x="12" y="8" width="3" height="1" fill="currentColor" />
                <rect x="5" y="10" width="3" height="1" fill="currentColor" />
                <rect x="9" y="10" width="6" height="1" fill="currentColor" />
                <rect x="5" y="12" width="9" height="1" fill="currentColor" />
                <rect x="5" y="14" width="6" height="1" fill="currentColor" />
                <rect x="12" y="14" width="3" height="1" fill="currentColor" />
                <rect x="3" y="17" width="14" height="1" fill="currentColor" />
                <rect x="4" y="18" width="12" height="1" fill="currentColor" />
              </svg>
            )}
            {type === 'guide' && (
              <svg viewBox="0 0 20 20" class="size-4" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="5" y="0" width="13" height="1" fill="currentColor" />
                <rect x="4" y="1" width="1" height="1" fill="currentColor" />
                <rect x="18" y="1" width="1" height="1" fill="currentColor" />
                <rect x="16" y="2" width="1" height="1" fill="currentColor" />
                <rect x="18" y="2" width="1" height="1" fill="currentColor" />
                <rect x="16" y="3" width="3" height="1" fill="currentColor" />
                <rect x="16" y="4" width="2" height="1" fill="currentColor" />
                <rect x="3" y="2" width="1" height="14" fill="currentColor" />
                <rect x="16" y="5" width="1" height="12" fill="currentColor" />
                <rect x="6" y="4" width="9" height="1" fill="currentColor" />
                <rect x="5" y="6" width="6" height="1" fill="currentColor" />
                <rect x="12" y="6" width="3" height="1" fill="currentColor" />
                <rect x="5" y="8" width="8" height="1" fill="currentColor" />
                <rect x="5" y="10" width="4" height="1" fill="currentColor" />
                <rect x="5" y="12" width="7" height="1" fill="currentColor" />
                <rect x="2" y="16" width="13" height="1" fill="currentColor" />
                <rect x="1" y="17" width="1" height="1" fill="currentColor" />
                <rect x="13" y="17" width="1" height="1" fill="currentColor" />
                <rect x="1" y="18" width="1" height="1" fill="currentColor" />
                <rect x="14" y="18" width="2" height="1" fill="currentColor" />
                <rect x="2" y="19" width="14" height="1" fill="currentColor" />
              </svg>
            )}
            {type === 'experiment' && (
              <svg viewBox="0 0 20 20" class="size-4" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="9" y="0" width="1" height="1" fill="currentColor" />
                <rect x="5" y="2" width="2" height="2" fill="currentColor" />
                <rect x="13" y="1" width="2" height="2" fill="currentColor" />
                <rect x="2" y="5" width="16" height="1" fill="currentColor" />
                <rect x="3" y="6" width="14" height="1" fill="currentColor" />
                <rect x="2" y="7" width="16" height="1" fill="currentColor" />
                <rect x="1" y="8" width="18" height="1" fill="currentColor" />
                <rect x="0" y="9" width="20" height="3" fill="currentColor" />
                <rect x="0" y="12" width="2" height="4" fill="currentColor" />
                <rect x="3" y="12" width="17" height="3" fill="currentColor" />
                <rect x="2" y="15" width="18" height="1" fill="currentColor" />
                <rect x="1" y="16" width="3" height="1" fill="currentColor" />
                <rect x="5" y="16" width="14" height="1" fill="currentColor" />
                <rect x="1" y="17" width="18" height="1" fill="currentColor" />
                <rect x="2" y="18" width="16" height="1" fill="currentColor" />
                <rect x="3" y="19" width="14" height="1" fill="currentColor" />
              </svg>
            )}
          </span>
          {showTypeLabel && (
            <span class="text-text-secondary font-mono text-[11px] font-semibold uppercase tracking-[0.08em]">
              {type}
            </span>
          )}
          <time class="text-text-secondary font-mono text-[13px]" datetime={date.toISOString()}>
            {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </time>
        </div>
        <!-- Desktop: type + date (icon is in the rail) -->
        <div class="hidden sm:flex items-baseline gap-3">
          {showTypeLabel && (
            <span class="text-text-secondary font-mono text-[11px] font-semibold uppercase tracking-[0.08em]">
              {type}
            </span>
          )}
          <time class="text-text-secondary font-mono text-[13px]" datetime={date.toISOString()}>
            {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </time>
