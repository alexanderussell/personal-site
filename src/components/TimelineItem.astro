---
import ExperimentRenderer from './ExperimentRenderer.astro';

interface Props {
  href: string;
  type: 'log' | 'guide' | 'experiment';
  title?: string;
  description?: string;
  date: Date;
  isLast?: boolean;
  showTypeLabel?: boolean;
  experimentId?: string;
}

const {
  href,
  type,
  title,
  description,
  date,
  isLast = false,
  showTypeLabel = true,
  experimentId,
} = Astro.props;
---

{
  type === 'experiment' && experimentId ? (
    <article class={`timeline-item timeline-item--${type} group grid grid-cols-1 sm:grid-cols-[2rem_1fr] gap-x-4 gap-y-0`}>
      <div class="timeline-rail hidden sm:block">
        <span class="timeline-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" class="size-5" fill="currentColor"><path d="M8 6h8v2H8zm0-4h8v2H8zm0 6h2v2H8zm6 0h2v2h-2zM6 20h12v2H6zm-2-8h2v8H4zm14 0h2v8h-2zM6 10h2v2H6zm10 0h2v2h-2zM6 4h2v2H6zm10 0h2v2h-2z"/></svg>
        </span>
        {!isLast && <span class="timeline-line" aria-hidden="true"></span>}
      </div>

      <div class="timeline-content">
        <a href={href} class="timeline-heading-link flex items-baseline gap-3 mb-2">
          <!-- Mobile: icon inline with type + date -->
          <div class="flex items-center gap-2 sm:hidden">
            <span class="timeline-icon-inline text-text-secondary" aria-hidden="true">
              <svg viewBox="0 0 24 24" class="size-4" fill="currentColor"><path d="M8 6h8v2H8zm0-4h8v2H8zm0 6h2v2H8zm6 0h2v2h-2zM6 20h12v2H6zm-2-8h2v8H4zm14 0h2v8h-2zM6 10h2v2H6zm10 0h2v2h-2zM6 4h2v2H6zm10 0h2v2h-2z"/></svg>
            </span>
            {showTypeLabel && (
              <span class="text-text-secondary font-mono text-[11px] font-semibold uppercase tracking-[0.08em]">
                {type}
              </span>
            )}
            <time class="text-text-secondary font-mono text-[13px]" datetime={date.toISOString()}>
              {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
          </div>
          <!-- Desktop: type + date (icon is in the rail) -->
          <div class="hidden sm:flex items-baseline gap-3">
            {showTypeLabel && (
              <span class="text-text-secondary font-mono text-[11px] font-semibold uppercase tracking-[0.08em]">
                {type}
              </span>
            )}
            <time class="text-text-secondary font-mono text-[13px]" datetime={date.toISOString()}>
              {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
          </div>
        </a>

        <!-- Desktop: experiment + maximize icon side by side -->
        <div class="flex items-start gap-3">
          <div class="experiment-container w-full sm:w-fit sm:max-w-xl" data-experiment-home data-experiment-href={href}>
            <ExperimentRenderer id={experimentId} />
          </div>
          <!-- TODO: Re-enable maximize button
          <button
            type="button"
            class="experiment-maximize hidden sm:block shrink-0 mt-1"
            aria-label="Open experiment in lightbox"
            data-experiment-maximize
          >
            <svg viewBox="0 0 16 16" class="size-4" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="0" y="0" width="6" height="2" fill="currentColor" />
              <rect x="0" y="2" width="2" height="4" fill="currentColor" />
              <rect x="10" y="0" width="6" height="2" fill="currentColor" />
              <rect x="14" y="2" width="2" height="4" fill="currentColor" />
              <rect x="0" y="10" width="2" height="4" fill="currentColor" />
              <rect x="0" y="14" width="6" height="2" fill="currentColor" />
              <rect x="14" y="10" width="2" height="4" fill="currentColor" />
              <rect x="10" y="14" width="6" height="2" fill="currentColor" />
            </svg>
          </button>
          -->
        </div>
      </div>
    </article>
  ) : (
    <a href={href} class={`timeline-item timeline-item--${type} group grid grid-cols-1 sm:grid-cols-[2rem_1fr] gap-x-4 gap-y-0`}>
      <div class="timeline-rail hidden sm:block">
        <span class="timeline-icon" aria-hidden="true">
          {type === 'log' && (
            <svg viewBox="0 0 24 24" class="size-5" fill="currentColor"><path d="M8 2h12v2H8zM6 4h2v16H6zm14 0h2v16h-2zM4 20h16v2H4zm-2-9h2v9H2zm2-2h2v2H4zm6-3h8v2h-8zm0 4h8v2h-8zm0-2h2v2h-2zm6 0h2v2h-2zm-6 5h8v2h-8zm0 3h4v2h-4z"/></svg>
          )}
          {type === 'guide' && (
            <svg viewBox="0 0 24 24" class="size-5" fill="currentColor"><path d="M2 3h9v2H2zM0 19h11v2H0zM13 3h9v2h-9zm0 16h11v2H13zM11 5h2v18h-2zM0 5h2v14H0zm22 0h2v14h-2zm-7 2h5v2h-5zm0 4h5v2h-5zm0 4h2v2h-2z"/></svg>
          )}
          {type === 'experiment' && (
            <svg viewBox="0 0 24 24" class="size-5" fill="currentColor"><path d="M8 6h8v2H8zm0-4h8v2H8zm0 6h2v2H8zm6 0h2v2h-2zM6 20h12v2H6zm-2-8h2v8H4zm14 0h2v8h-2zM6 10h2v2H6zm10 0h2v2h-2zM6 4h2v2H6zm10 0h2v2h-2z"/></svg>
          )}
        </span>
        {!isLast && <span class="timeline-line" aria-hidden="true"></span>}
      </div>

      <div class="timeline-content">
        <!-- Mobile: icon + type inline, stacked above title -->
        <div class="flex items-center gap-2 sm:hidden">
          <span class="timeline-icon-inline text-text-secondary" aria-hidden="true">
            {type === 'log' && (
              <svg viewBox="0 0 24 24" class="size-4" fill="currentColor"><path d="M8 2h12v2H8zM6 4h2v16H6zm14 0h2v16h-2zM4 20h16v2H4zm-2-9h2v9H2zm2-2h2v2H4zm6-3h8v2h-8zm0 4h8v2h-8zm0-2h2v2h-2zm6 0h2v2h-2zm-6 5h8v2h-8zm0 3h4v2h-4z"/></svg>
            )}
            {type === 'guide' && (
              <svg viewBox="0 0 24 24" class="size-4" fill="currentColor"><path d="M2 3h9v2H2zM0 19h11v2H0zM13 3h9v2h-9zm0 16h11v2H13zM11 5h2v18h-2zM0 5h2v14H0zm22 0h2v14h-2zm-7 2h5v2h-5zm0 4h5v2h-5zm0 4h2v2h-2z"/></svg>
            )}
            {type === 'experiment' && (
              <svg viewBox="0 0 24 24" class="size-4" fill="currentColor"><path d="M8 6h8v2H8zm0-4h8v2H8zm0 6h2v2H8zm6 0h2v2h-2zM6 20h12v2H6zm-2-8h2v8H4zm14 0h2v8h-2zM6 10h2v2H6zm10 0h2v2h-2zM6 4h2v2H6zm10 0h2v2h-2z"/></svg>
            )}
          </span>
          {showTypeLabel && (
            <span class="text-text-secondary font-mono text-[11px] font-semibold uppercase tracking-[0.08em]">
              {type}
            </span>
          )}
          <time class="text-text-secondary font-mono text-[13px]" datetime={date.toISOString()}>
            {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </time>
        </div>
        <!-- Desktop: type + date (icon is in the rail) -->
        <div class="hidden sm:flex items-baseline gap-3">
          {showTypeLabel && (
            <span class="text-text-secondary font-mono text-[11px] font-semibold uppercase tracking-[0.08em]">
              {type}
            </span>
          )}
          <time class="text-text-secondary font-mono text-[13px]" datetime={date.toISOString()}>
            {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </time>
        </div>
        <h3 class="text-text-primary mt-1.5 text-lg font-semibold transition-colors">{title}</h3>
        <p class="text-text-secondary mt-1 text-sm leading-relaxed">{description}</p>
      </div>
    </a>
  )
}

<script>
  /*
  // TODO: Screen/code toggle icons — re-enable when ready
  const ICON_SCREEN = `<svg viewBox="0 0 16 16" width="16" height="16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="1" y="2" width="14" height="2" fill="currentColor" />
    <rect x="0" y="4" width="16" height="7" fill="currentColor" />
    <rect x="1" y="11" width="14" height="1" fill="currentColor" />
    <rect x="2" y="3" width="12" height="1" fill="var(--color-bg-primary, #111)" />
    <rect x="1" y="4" width="14" height="6" fill="var(--color-bg-primary, #111)" />
    <rect x="6" y="12" width="4" height="1" fill="currentColor" />
    <rect x="5" y="13" width="6" height="1" fill="currentColor" />
  </svg>`;

  const ICON_CODE = `<svg viewBox="0 0 16 16" width="16" height="16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="4" y="1" width="2" height="2" fill="currentColor" />
    <rect x="2" y="3" width="2" height="2" fill="currentColor" />
    <rect x="0" y="5" width="2" height="2" fill="currentColor" />
    <rect x="0" y="7" width="2" height="2" fill="currentColor" />
    <rect x="2" y="9" width="2" height="2" fill="currentColor" />
    <rect x="2" y="11" width="2" height="2" fill="currentColor" />
    <rect x="4" y="13" width="2" height="2" fill="currentColor" />
    <rect x="10" y="1" width="2" height="2" fill="currentColor" />
    <rect x="12" y="3" width="2" height="2" fill="currentColor" />
    <rect x="14" y="5" width="2" height="2" fill="currentColor" />
    <rect x="14" y="7" width="2" height="2" fill="currentColor" />
    <rect x="12" y="9" width="2" height="2" fill="currentColor" />
    <rect x="12" y="11" width="2" height="2" fill="currentColor" />
    <rect x="10" y="13" width="2" height="2" fill="currentColor" />
  </svg>`;
  */

  const ICON_CLOSE = `<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M6 2h12v2H6zm0 18h12v2H6zM2 6h2v12H2zm18 0h2v12h-2zm-2-2h2v2h-2zm-2 2h2v2h-2zm-2 2h2v2h-2zm-2 2h2v2h-2zm-2 2h2v2h-2zm-2 2h2v2H8zm-2 2h2v2H6zm12 2h2v2h-2zM4 4h2v2H4zm0 14h2v2H4z"/></svg>`;

  const ICON_OPEN = `<svg viewBox="0 0 16 16" width="16" height="16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="1" y="3" width="10" height="2" fill="currentColor" />
    <rect x="0" y="5" width="12" height="8" fill="currentColor" />
    <rect x="1" y="13" width="10" height="1" fill="currentColor" />
    <rect x="1" y="5" width="10" height="7" fill="var(--color-bg-primary, #111)" />
    <rect x="10" y="1" width="2" height="2" fill="currentColor" />
    <rect x="12" y="1" width="4" height="2" fill="currentColor" />
    <rect x="14" y="1" width="2" height="6" fill="currentColor" />
    <rect x="12" y="3" width="2" height="2" fill="currentColor" />
    <rect x="10" y="5" width="2" height="2" fill="currentColor" />
  </svg>`;

  function openLightbox(experimentHome: HTMLElement) {
    const href = experimentHome.dataset.experimentHref || '';
    const overlay = document.createElement('div');
    overlay.className = 'experiment-lightbox';
    overlay.innerHTML = `
      <div class="experiment-lightbox-backdrop"></div>
      <div class="experiment-lightbox-content">
        <div class="experiment-lightbox-actions">
          ${href ? `<a href="${href}" class="experiment-lightbox-open" aria-label="Open experiment page">${ICON_OPEN}</a>` : ''}
          <button type="button" class="experiment-lightbox-close" aria-label="Close lightbox">
            ${ICON_CLOSE}
          </button>
        </div>
        <div class="experiment-lightbox-stage">
          <div class="experiment-lightbox-render"></div>
        </div>
      </div>
    `;

    document.body.appendChild(overlay);
    const renderPane = overlay.querySelector('.experiment-lightbox-render')!;

    // Move experiment into lightbox render pane
    const children = Array.from(experimentHome.children);
    children.forEach((child) => renderPane.appendChild(child));

    function closeLightbox() {
      // Move experiment back
      children.forEach((child) => experimentHome.appendChild(child));
      overlay.remove();
      document.removeEventListener('keydown', onKey);
    }

    function onKey(e: KeyboardEvent) {
      if (e.key === 'Escape') closeLightbox();
    }

    document.addEventListener('keydown', onKey);
    overlay.querySelector('.experiment-lightbox-backdrop')!.addEventListener('click', closeLightbox);
    overlay.querySelector('.experiment-lightbox-close')!.addEventListener('click', closeLightbox);
  }

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const button = target.closest('[data-experiment-maximize]');
    if (!(button instanceof HTMLButtonElement)) return;

    const article = button.closest('.timeline-item--experiment');
    if (!article) return;

    const home = article.querySelector('[data-experiment-home]');
    if (!(home instanceof HTMLElement)) return;

    openLightbox(home);
  });
</script>
