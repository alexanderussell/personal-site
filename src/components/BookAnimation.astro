---
// 3D floating book with orbiting code fragments.
// Pure CSS — no dependencies.
---

<div class="book-scene" aria-hidden="true">
  <!-- Orbiting fragments — hints at the subject -->
  <span class="book-fragment book-fragment--1">{'>'}_</span>
  <span class="book-fragment book-fragment--2">/skill</span>
  <span class="book-fragment book-fragment--3">ux</span>
  <span class="book-fragment book-fragment--4">ai</span>
  <span class="book-fragment book-fragment--5">design</span>
  <span class="book-fragment book-fragment--6">→</span>

  <!-- 3D Book -->
  <div class="book">
    <div class="book__spine"></div>
    <div class="book__cover book__cover--front">
      <div class="book__cover-content">
        <div class="book__cover-line book__cover-line--title"></div>
        <div class="book__cover-line book__cover-line--subtitle"></div>
        <div class="book__cover-divider"></div>
        <div class="book__cover-line book__cover-line--author"></div>
      </div>
      <!-- Faint terminal cursor -->
      <div class="book__cursor">_</div>
    </div>
    <div class="book__cover book__cover--back"></div>
    <div class="book__pages">
      <div class="book__page-edge"></div>
      <div class="book__page-edge"></div>
      <div class="book__page-edge"></div>
    </div>
  </div>

  <!-- Shadow on surface -->
  <div class="book__shadow"></div>
</div>

<style>
  .book-scene {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    width: 220px;
    height: 240px;
    perspective: 600px;
    color: var(--color-text-primary);
  }

  /* ── 3D Book ── */
  .book {
    position: relative;
    width: 120px;
    height: 160px;
    transform-style: preserve-3d;
    transform: rotateY(-22deg) rotateX(6deg);
    animation: book-float 4s ease-in-out infinite;
  }

  .book__cover {
    position: absolute;
    width: 120px;
    height: 160px;
    border-radius: 2px 6px 6px 2px;
    backface-visibility: hidden;
  }

  .book__cover--front {
    background: var(--color-bg-secondary);
    border: 1.5px solid var(--color-border);
    transform: translateZ(8px);
    overflow: hidden;
  }

  .book__cover--back {
    background: var(--color-bg-secondary);
    border: 1.5px solid var(--color-border);
    transform: translateZ(-8px) rotateY(180deg);
  }

  .book__spine {
    position: absolute;
    left: 0;
    width: 16px;
    height: 160px;
    background: var(--color-border);
    border-radius: 2px 0 0 2px;
    transform: rotateY(-90deg) translateZ(0px) translateX(-8px);
    opacity: 0.6;
  }

  /* ── Cover content ── */
  .book__cover-content {
    position: absolute;
    top: 28px;
    left: 16px;
    right: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .book__cover-line {
    height: 3px;
    border-radius: 1px;
    background: currentColor;
  }

  .book__cover-line--title {
    width: 80%;
    opacity: 0.25;
  }

  .book__cover-line--subtitle {
    width: 55%;
    height: 2px;
    opacity: 0.15;
  }

  .book__cover-divider {
    width: 20px;
    height: 1px;
    background: currentColor;
    opacity: 0.12;
    margin: 8px 0;
  }

  .book__cover-line--author {
    width: 40%;
    height: 2px;
    opacity: 0.12;
  }

  /* Terminal cursor on cover */
  .book__cursor {
    position: absolute;
    bottom: 20px;
    right: 16px;
    font-family: var(--font-mono);
    font-size: 14px;
    opacity: 0.2;
    animation: cursor-blink 1s step-end infinite;
  }

  /* ── Page edges ── */
  .book__pages {
    position: absolute;
    top: 4px;
    right: -1px;
    width: 2px;
    height: 152px;
    display: flex;
    flex-direction: column;
    gap: 1px;
    transform: translateZ(4px);
  }

  .book__page-edge {
    flex: 1;
    background: currentColor;
    opacity: 0.08;
    border-radius: 0 1px 1px 0;
  }

  /* ── Shadow ── */
  .book__shadow {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 100px;
    height: 12px;
    background: radial-gradient(ellipse, oklch(0% 0 0 / 0.1) 0%, transparent 70%);
    transform: translateX(-50%);
    animation: shadow-pulse 4s ease-in-out infinite;
  }

  :where(.dark) .book__shadow {
    background: radial-gradient(ellipse, oklch(100% 0 0 / 0.04) 0%, transparent 70%);
  }

  /* ── Floating fragments ── */
  .book-fragment {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    opacity: 0;
    pointer-events: none;
    color: var(--color-text-secondary);
    animation: fragment-drift 6s ease-in-out infinite;
  }

  .book-fragment--1 {
    top: 15%;
    right: 8%;
    animation-delay: 0s;
    font-size: 12px;
    opacity: 0;
  }

  .book-fragment--2 {
    bottom: 28%;
    left: 2%;
    animation-delay: 1s;
    font-size: 9px;
  }

  .book-fragment--3 {
    top: 8%;
    left: 15%;
    animation-delay: 2s;
    text-transform: uppercase;
    font-size: 9px;
    letter-spacing: 0.15em;
  }

  .book-fragment--4 {
    bottom: 18%;
    right: 5%;
    animation-delay: 3.2s;
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.15em;
  }

  .book-fragment--5 {
    top: 40%;
    left: 0%;
    animation-delay: 4.5s;
    font-size: 8px;
    letter-spacing: 0.1em;
  }

  .book-fragment--6 {
    top: 55%;
    right: 2%;
    animation-delay: 2.8s;
    font-size: 14px;
  }

  /* ── Animations ── */
  @keyframes book-float {
    0%, 100% {
      transform: rotateY(-22deg) rotateX(6deg) translateY(0);
    }
    50% {
      transform: rotateY(-22deg) rotateX(6deg) translateY(-10px);
    }
  }

  @keyframes shadow-pulse {
    0%, 100% {
      transform: translateX(-50%) scale(1);
      opacity: 1;
    }
    50% {
      transform: translateX(-50%) scale(0.85);
      opacity: 0.6;
    }
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 0; }
  }

  @keyframes fragment-drift {
    0% {
      opacity: 0;
      transform: translateY(6px) scale(0.95);
    }
    15% {
      opacity: 0.35;
      transform: translateY(0) scale(1);
    }
    40% {
      opacity: 0.35;
      transform: translateY(-4px) scale(1);
    }
    55% {
      opacity: 0;
      transform: translateY(-10px) scale(0.95);
    }
    100% {
      opacity: 0;
      transform: translateY(6px) scale(0.95);
    }
  }

  /* ── Dark mode glow ── */
  :where(.dark) .book__cover--front {
    box-shadow: 0 0 20px oklch(100% 0 0 / 0.04);
  }

  :where(.dark) .book-fragment {
    color: var(--color-text-primary);
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .book { animation: none; }
    .book__shadow { animation: none; }
    .book__cursor { animation: none; }
    .book-fragment { animation: none; opacity: 0.2; }
  }
</style>
