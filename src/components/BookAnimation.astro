---
// CSS-only floating book animation using site design tokens.
// No external dependencies.
---

<div class="book-animation" aria-hidden="true">
  <svg
    class="book-svg"
    viewBox="0 0 80 100"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    width="80"
    height="100"
  >
    <!-- Book spine -->
    <rect x="0" y="2" width="10" height="96" rx="1" fill="currentColor" opacity="0.25" />
    <!-- Book cover -->
    <rect x="8" y="0" width="72" height="100" rx="2" fill="currentColor" opacity="0.08" />
    <rect x="8" y="0" width="72" height="100" rx="2" stroke="currentColor" stroke-width="1.5" opacity="0.3" />
    <!-- Spine highlight -->
    <rect x="8" y="0" width="4" height="100" rx="1" fill="currentColor" opacity="0.15" />
    <!-- Cover lines (text suggestion) -->
    <rect x="20" y="22" width="44" height="3" rx="1" fill="currentColor" opacity="0.2" />
    <rect x="20" y="30" width="36" height="2" rx="1" fill="currentColor" opacity="0.13" />
    <rect x="20" y="55" width="28" height="2" rx="1" fill="currentColor" opacity="0.1" />
    <rect x="20" y="61" width="22" height="2" rx="1" fill="currentColor" opacity="0.1" />
    <!-- Bottom page edges suggestion -->
    <rect x="10" y="96" width="68" height="1" rx="0.5" fill="currentColor" opacity="0.12" />
    <rect x="10" y="94" width="68" height="1" rx="0.5" fill="currentColor" opacity="0.08" />
  </svg>
</div>

<style>
  .book-animation {
    display: flex;
    justify-content: center;
    align-items: center;
    color: var(--color-text-primary);
  }

  .book-svg {
    animation: book-float 3.2s ease-in-out infinite;
    filter: drop-shadow(0 8px 16px oklch(0% 0 0 / 0.08));
  }

  @keyframes book-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .book-svg {
      animation: none;
    }
  }
</style>
