---
import ThemeToggle from './ThemeToggle.astro';
import GenerativeLogo from './GenerativeLogo.astro';

const navLinks = [
  { href: '/logs', label: 'Logs' },
  { href: '/guides', label: 'Guides' },
  { href: '/experiments', label: 'Experiments' },
];

const currentPath = Astro.url.pathname;
---

<nav>
  <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-4">
    <div class="flex items-center gap-2.5">
      <div class="size-8 sm:size-10 shrink-0">
        <GenerativeLogo />
      </div>
      <a href="/" class="text-text-primary font-heading text-xl tracking-[-0.01em] hover:opacity-80 transition-opacity">
        Alexander Russell
      </a>
    </div>
    <div class="flex items-center gap-6">
      <div class="hidden items-center gap-6 sm:flex">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'font-mono text-[13px] transition-colors',
              currentPath.startsWith(href) ? 'text-text-primary font-medium' : 'text-text-secondary hover:text-text-primary',
            ]}
          >
            {label}
          </a>
        ))}
      </div>
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Open menu"
        class="text-secondary hover:text-primary cursor-pointer sm:hidden transition-colors"
      >
        <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20 18H4v-2h16v2Zm0-5H4v-2h16v2Zm0-5H4V6h16v2Z"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-border/50 border-t sm:hidden">
    <div class="mx-auto max-w-3xl space-y-1 px-6 py-3">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'block py-2 font-mono text-sm transition-colors',
            currentPath.startsWith(href) ? 'text-text-primary font-medium' : 'text-text-secondary hover:text-text-primary',
          ]}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
