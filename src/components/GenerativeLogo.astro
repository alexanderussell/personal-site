---
// GenerativeLogo.astro
// Generative identity mark — overlapping rotated color planes
// with additive blending. Animates transitions on regenerate.
---

<div class="generative-logo" data-generative-logo>
  <canvas data-generative-canvas></canvas>
</div>

<script is:inline>
  (() => {
    const SIZE = 400;
    const DURATION = 800;
    const STAGGER = 120;
    const GRAIN = 14;

    const PALETTE = [
      [200, 42, 40],
      [220, 172, 22],
      [30, 90, 195],
      [18, 160, 120],
    ];

    function rand(lo, hi) { return lo + Math.random() * (hi - lo); }

    function parseBgColor() {
      const style = getComputedStyle(document.documentElement);
      const bg = style.getPropertyValue('--color-bg-primary').trim();
      const tmp = document.createElement('canvas');
      tmp.width = 1; tmp.height = 1;
      const tctx = tmp.getContext('2d');
      tctx.fillStyle = bg;
      tctx.fillRect(0, 0, 1, 1);
      const [r, g, b] = tctx.getImageData(0, 0, 1, 1).data;
      return [r, g, b];
    }

    function isLightBg(rgb) {
      return (rgb[0] * 0.299 + rgb[1] * 0.587 + rgb[2] * 0.114) > 140;
    }

    function cubicBezier(x1, y1, x2, y2) {
      return function(t) {
        let x = t;
        for (let i = 0; i < 8; i++) {
          const cx = 3 * x1 * x * (1 - x) * (1 - x) + 3 * x2 * x * x * (1 - x) + x * x * x - t;
          const dx = 3 * x1 * (1 - x) * (1 - x) - 6 * x1 * x * (1 - x) + 6 * x2 * x * (1 - x) - 3 * x2 * x * x + 3 * x * x;
          if (Math.abs(dx) < 1e-6) break;
          x -= cx / dx;
        }
        return 3 * y1 * x * (1 - x) * (1 - x) + 3 * y2 * x * x * (1 - x) + x * x * x;
      };
    }

    const ease = cubicBezier(0.25, 0.1, 0.25, 1.0);

    function lerp(a, b, t) { return a + (b - a) * t; }

    function lerpColor(a, b, t) {
      return [
        Math.round(lerp(a[0], b[0], t)),
        Math.round(lerp(a[1], b[1], t)),
        Math.round(lerp(a[2], b[2], t)),
      ];
    }

    function generateBlockState() {
      const colors = PALETTE.slice().sort(() => Math.random() - 0.5).slice(0, Math.random() < 0.4 ? 4 : 3);
      return colors.map(c => ({
        cx: rand(SIZE * 0.15, SIZE * 0.85),
        cy: rand(SIZE * 0.15, SIZE * 0.85),
        w: rand(SIZE * 0.35, SIZE * 0.75),
        h: rand(SIZE * 0.25, SIZE * 0.6),
        angle: rand(-Math.PI * 0.4, Math.PI * 0.4),
        alpha: rand(0.55, 0.8),
        color: c,
      }));
    }

    function drawFrame(ctx, blocks, grain) {
      const bgRgb = parseBgColor();
      const light = isLightBg(bgRgb);

      const tr = Math.min(255, bgRgb[0] + (light ? -4 : 6));
      const tg = Math.min(255, bgRgb[1] + (light ? -2 : 3));
      const tb = Math.max(0, bgRgb[2] + (light ? -6 : -2));
      ctx.globalCompositeOperation = 'source-over';
      ctx.fillStyle = `rgb(${tr},${tg},${tb})`;
      ctx.fillRect(0, 0, SIZE, SIZE);

      ctx.globalCompositeOperation = light ? 'multiply' : 'lighter';

      for (const b of blocks) {
        ctx.save();
        ctx.translate(b.cx, b.cy);
        ctx.rotate(b.angle);
        if (light) {
          const lr = Math.min(255, b.color[0] + 40);
          const lg = Math.min(255, b.color[1] + 40);
          const lb = Math.min(255, b.color[2] + 40);
          ctx.fillStyle = `rgba(${lr},${lg},${lb},${b.alpha})`;
        } else {
          ctx.fillStyle = `rgba(${b.color[0]},${b.color[1]},${b.color[2]},${b.alpha})`;
        }
        ctx.fillRect(-b.w / 2, -b.h / 2, b.w, b.h);
        ctx.restore();
      }

      ctx.globalCompositeOperation = 'source-over';
      if (grain > 0) {
        const imageData = ctx.getImageData(0, 0, SIZE, SIZE);
        const d = imageData.data;
        for (let i = 0; i < d.length; i += 4) {
          const noise = (Math.random() - 0.5) * grain;
          d[i]     = Math.min(255, Math.max(0, d[i] + noise));
          d[i + 1] = Math.min(255, Math.max(0, d[i + 1] + noise));
          d[i + 2] = Math.min(255, Math.max(0, d[i + 2] + noise));
        }
        ctx.putImageData(imageData, 0, 0);
      }
    }

    function animateTransition(ctx, fromBlocks, toBlocks, onDone) {
      const maxLen = Math.max(fromBlocks.length, toBlocks.length);
      const from = fromBlocks.slice();
      const to = toBlocks.slice();
      while (from.length < maxLen) {
        const target = to[from.length];
        from.push({ ...target, alpha: 0, w: 0, h: 0 });
      }
      while (to.length < maxLen) {
        const source = from[to.length];
        to.push({ ...source, alpha: 0, w: 0, h: 0 });
      }

      const start = performance.now();
      let rafId;

      function tick(now) {
        const elapsed = now - start;
        const totalDuration = DURATION + STAGGER * (maxLen - 1);

        const interpolated = from.map((f, i) => {
          const blockStart = STAGGER * i;
          const blockT = Math.max(0, Math.min(1, (elapsed - blockStart) / DURATION));
          const t = ease(blockT);
          const target = to[i];
          return {
            cx: lerp(f.cx, target.cx, t),
            cy: lerp(f.cy, target.cy, t),
            w: lerp(f.w, target.w, t),
            h: lerp(f.h, target.h, t),
            angle: lerp(f.angle, target.angle, t),
            alpha: lerp(f.alpha, target.alpha, t),
            color: lerpColor(f.color, target.color, t),
          };
        });

        drawFrame(ctx, interpolated, elapsed >= totalDuration ? GRAIN : 0);

        if (elapsed < totalDuration) {
          rafId = requestAnimationFrame(tick);
        } else {
          drawFrame(ctx, to, GRAIN);
          if (onDone) onDone();
        }
      }

      rafId = requestAnimationFrame(tick);
      return () => cancelAnimationFrame(rafId);
    }

    function updateFavicon(sourceCanvas) {
      const tiny = document.createElement('canvas');
      tiny.width = 32;
      tiny.height = 32;
      const tctx = tiny.getContext('2d');
      tctx.drawImage(sourceCanvas, 0, 0, 32, 32);
      const url = tiny.toDataURL('image/png');
      let link = document.querySelector('link[rel="icon"]');
      if (!link) {
        link = document.createElement('link');
        link.rel = 'icon';
        document.head.appendChild(link);
      }
      link.href = url;
    }

    function initHero(root) {
      if (root.dataset.heroInit) return;
      root.dataset.heroInit = '1';

      const canvas = root.querySelector('[data-generative-canvas]');
      if (!canvas) return;

      const ctx = canvas.getContext('2d');
      canvas.width = SIZE;
      canvas.height = SIZE;

      let currentBlocks = generateBlockState();
      let animating = false;

      drawFrame(ctx, currentBlocks, GRAIN);
      updateFavicon(canvas);

      root.addEventListener('click', () => {
        if (animating) return;
        const nextBlocks = generateBlockState();
        animating = true;
        animateTransition(ctx, currentBlocks, nextBlocks, () => {
          currentBlocks = nextBlocks;
          animating = false;
          updateFavicon(canvas);
        });
      });

      root.style.cursor = 'pointer';
    }

    function initAll() {
      document.querySelectorAll('[data-generative-logo]').forEach((el) => {
        if (el instanceof HTMLElement) initHero(el);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAll, { once: true });
    } else {
      initAll();
    }
  })();
</script>
