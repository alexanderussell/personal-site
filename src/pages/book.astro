---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import BookAnimation from '../components/BookAnimation.astro';
import { SubscribeForm } from '../components/SubscribeForm';
---

<BaseLayout
  title="Designing with AI — Alex Russell"
  description="A framework for making UX decisions when your tools can think. Sign up for updates."
>
  <div class="book-page">
    <div class="book-page__animation fade-in-hidden" data-book-animate>
      <BookAnimation />
    </div>

    <div class="book-page__content fade-in-hidden" data-book-animate>
      <h1 class="book-page__title">Designing with AI</h1>
      <p class="book-page__body">
        A framework for making UX decisions when your tools can think.
        Part book, part course, part hands-on toolkit — built around the
        workflows and skills that actually ship.
      </p>
    </div>

    <div class="book-page__form fade-in-hidden" data-book-animate>
      <SubscribeForm list="book" client:load />
    </div>

    <p class="book-page__note fade-in-hidden" data-book-animate>
      Still taking shape. Sign up and I'll reach out when it's real.
    </p>
  </div>
</BaseLayout>

<script>
  const items = document.querySelectorAll('[data-book-animate]');
  let delay = 120;
  items.forEach((item) => {
    setTimeout(() => item.classList.add('is-visible'), delay);
    delay += 140;
  });
</script>

<style>
  .book-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 1rem 6rem;
    gap: 0;
  }

  .book-page__animation {
    margin-bottom: 2.5rem;
  }

  .book-page__content {
    margin-bottom: 1.5rem;
  }

  .book-page__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin: 0 0 0.75rem;
  }

  .book-page__body {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 400px;
    margin: 0 auto;
  }

  .book-page__form {
    width: 100%;
    max-width: 380px;
    margin-bottom: 1.25rem;
  }

  .book-page__note {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-secondary);
    opacity: 0.7;
    margin: 0;
    letter-spacing: 0.02em;
  }
</style>
