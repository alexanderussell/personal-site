---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import TimelineItem from '../../components/TimelineItem.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Notes — Alex Russell" description="Short-form writing — essays, philosophies, learnings, reflections.">
  <section class="py-16">
    <p class="font-mono text-sm uppercase font-semibold text-text-secondary tracking-tight">Notes</p>
    <h1 class="mt-3 font-heading text-xl leading-snug sm:text-2xl sm:leading-[1.35]">Essays written with conviction and edited with doubt.    </h1>

    <div class="mt-12">
      {notes.map((note, index) => (
        <TimelineItem
          href={`/notes/${note.id}`}
          type="note"
          title={note.data.title}
          description={note.data.description}
          date={note.data.date}
          isLast={index === notes.length - 1}
          showTypeLabel={false}
        />
      ))}
    </div>
  </section>
</BaseLayout>
