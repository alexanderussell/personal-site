---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import ExperimentRenderer from '../../components/ExperimentRenderer.astro';

export async function getStaticPaths() {
  const experiments = (await getCollection('experiments')).sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
  return experiments.map((entry, i) => ({
    params: { slug: entry.id },
    props: { entry, number: i + 1 },
  }));
}

const { entry, number } = Astro.props;
const { Content } = await render(entry);
---

<PostLayout
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
  type="experiment"
  subtitle={entry.data.subtitle}
  number={number}
>
  <ExperimentRenderer id={entry.id} />
  <Content />
</PostLayout>
