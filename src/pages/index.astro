---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import TimelineItem from '../components/TimelineItem.astro';
const allLogs = await getCollection('logs', ({ data }) => !data.draft);
const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const allExperiments = await getCollection('experiments', ({ data }) => !data.draft);

type TimelineEntry = {
  id: string;
  type: 'log' | 'guide' | 'experiment';
  title?: string;
  description?: string;
  date: Date;
  href: string;
  experimentId?: string;
};

const timeline: TimelineEntry[] = [
  ...allLogs.map((entry) => ({
    id: entry.id,
    type: 'log' as const,
    title: entry.data.title,
    description: entry.data.description,
    date: entry.data.date,
    href: `/logs/${entry.id}`,
  })),
  ...allGuides.map((entry) => ({
    id: entry.id,
    type: 'guide' as const,
    title: entry.data.title,
    description: entry.data.description,
    date: entry.data.date,
    href: `/guides/${entry.id}`,
  })),
  ...allExperiments.map((entry) => ({
    id: entry.id,
    type: 'experiment' as const,
    date: entry.data.date,
    href: `/experiments/${entry.id}`,
    experimentId: entry.id,
  })),
]
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 15);

---

<BaseLayout>
  <!-- About -->
  <section class="flex flex-col gap-3 pt-12 sm:pt-12">
    <p class="font-heading text-2xl leading-snug sm:text-[32px] sm:leading-[1.35] fade-in-hidden" data-stagger>
      Hey, I'm Alex — a design engineer with 12 years of making software feel like something.
    </p>
    <p class="font-mono text-base leading-7 text-text-secondary fade-in-hidden" data-stagger>
      Right now I lead UX for developer tools at <a href="https://marriott.com" id="marriott-link" class="font-semibold prose dark:prose-invert hover:underline" target="_blank" rel="noopener noreferrer">Marriott International</a>, designing the internal
      platforms that engineering teams use to ship infrastructure.
    </p>
    <p class="font-mono text-base leading-7 text-text-secondary fade-in-hidden" data-stagger>
      Before that, I spent years inside agencies, dev shops, and startups — wearing every hat, shipping everything from
      brand systems to full product builds. Somewhere in the middle I started a design collective called <a href="https://collectivelymade.com" id="cm-link" target="_blank" rel="noopener noreferrer" class="font-semibold prose dark:prose-invert hover:underline">Collectively Made</a>.
    </p>
  </section>

  <!-- Tooltips -->
  <div class="hover-tooltip" id="marriott-tooltip"></div>
  <div class="hover-tooltip" id="cm-tooltip"></div>

  <script>
    // ── Stagger animate all [data-stagger] and [data-timeline-animate] ──
    const staggerItems = document.querySelectorAll('[data-stagger]');
    const timelineItems = document.querySelectorAll('[data-timeline-animate]');

    let delay = 100;
    staggerItems.forEach((item) => {
      setTimeout(() => item.classList.add('is-visible'), delay);
      delay += 120;
    });

    // Timeline staggers in after intro paragraphs
    delay += 100;
    timelineItems.forEach((item) => {
      setTimeout(() => item.classList.add('is-visible'), delay);
      delay += 60;
    });

    // ── Rotating tooltips ──
    function setupTooltip(linkId: string, tooltipId: string, phrases: string[]) {
      const link = document.getElementById(linkId)!;
      const tooltip = document.getElementById(tooltipId)!;
      let index = 0;

      link.addEventListener('mouseenter', () => {
        tooltip.textContent = phrases[index % phrases.length];
        index++;
        tooltip.classList.add('is-visible');
      });

      link.addEventListener('mouseleave', () => {
        tooltip.classList.remove('is-visible');
      });

      link.addEventListener('mousemove', (e: MouseEvent) => {
        tooltip.style.left = `${e.clientX + 12}px`;
        tooltip.style.top = `${e.clientY - 32}px`;
      });
    }

    setupTooltip('marriott-link', 'marriott-tooltip', [
      '🏨 yes, the hotel people',
      '🛎️ the towel-folding empire',
      '✈️ points guy paradise',
    ]);

    setupTooltip('cm-link', 'cm-tooltip', [
      '🤝 we made things, collectively',
      '🧥 a bunch of designers in a trench coat',
      '💭 the "we should start a studio" phase',
    ]);
  </script>

  <!-- CTA row — extensible flex container for homepage buttons -->
  <div class="flex gap-3 mt-16 fade-in-hidden" data-stagger>
    <a
      href="/book"
      class="font-mono text-[11px] uppercase tracking-[0.12em] text-text-secondary border border-border px-3.5 py-1.5 rounded-md hover:text-text-primary hover:border-accent transition-all duration-300"
    >
      My Book
    </a>
  </div>

  <!-- Timeline -->
  {timeline.length > 0 && (
    <section class="py-16" id="timeline-section">
      <h2 class="text-text-secondary mb-8 font-mono text-[13px] uppercase tracking-[0.12em] fade-in-hidden" data-timeline-animate>Recent</h2>
      <div>
        {timeline.map((item, index) => (
          <div class="fade-in-hidden" data-timeline-animate>
            <TimelineItem
              href={item.href}
              type={item.type}
              title={item.title}
              description={item.description}
              date={item.date}
              isLast={index === timeline.length - 1}
              experimentId={item.experimentId}
            />
          </div>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
